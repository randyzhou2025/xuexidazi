# 复制为 .env.prod 后填写，勿提交 .env.prod
# docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
#
# 方案 B：通过 Docker 网络直连 Postgres 容器（host 用容器名，端口 5432）
# 查各项目实际网络名：
#   docker inspect exam_postgres  --format '{{range $k,$v := .NetworkSettings.Networks}}{{$k}}{{"\n"}}{{end}}'
#   docker inspect ptoe_postgres  --format '{{range $k,$v := .NetworkSettings.Networks}}{{$k}}{{"\n"}}{{end}}'
#   docker inspect gotit_postgres --format '{{range $k,$v := .NetworkSettings.Networks}}{{$k}}{{"\n"}}{{end}}'

# 宿主机映射，默认仅本机 8090（宝塔反代用）
XUEXIDAZI_BIND=127.0.0.1:8090

# 各项目 compose 默认网络（目录名小写 + _default）；若 inspect 结果不同请改掉
EXAM_DOCKER_NETWORK=exammaster_default
PTOE_DOCKER_NETWORK=periodictable_default
GOTIT_DOCKER_NETWORK=gotit_default

# StudyMate 公共用户库（ExamMaster）
# 密码：ExamMaster/.env.prod → EXAM_POSTGRES_PASSWORD
XUEXIDAZI_DATABASE_URL=postgresql://exam:CHANGE_ME@exam_postgres:5432/exam_master

JWT_SECRET=change-me-at-least-32-chars-in-production
JWT_EXPIRES_IN=7d

# 可选：PeriodicTable（密码 → PTOE_POSTGRES_PASSWORD；SESSION → SESSION_SECRET）
PTOE_DATABASE_URL=postgresql://ptoe:CHANGE_ME@ptoe_postgres:5432/periodic_table_auth
PTOE_SESSION_SECRET=change-me-at-least-32-chars
PTOE_IDLE_RELEASE_DAYS=30
PTOE_MAX_DEVICES_DEFAULT=2

# 可选：GotIt（密码 → GOTIT_POSTGRES_PASSWORD）
GOTIT_DATABASE_URL=postgresql://gotit:CHANGE_ME@gotit_postgres:5432/gotit

# 复制为 .env.prod 后填写，勿提交 .env.prod
# docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# 宿主机映射，默认仅本机 8090；对外可改为 0.0.0.0:8090
XUEXIDAZI_BIND=127.0.0.1:8090

# StudyMate 公共用户库（ExamMaster Postgres）
# 同机 Docker：host 用 host.docker.internal，端口按实际映射（ExamMaster 默认 5433→5432）
XUEXIDAZI_DATABASE_URL=postgresql://exam:CHANGE_ME@host.docker.internal:5433/exam_master

JWT_SECRET=change-me-at-least-32-chars-in-production
JWT_EXPIRES_IN=7d

# 可选：PeriodicTable 授权库（不配置则 padmin 周期表菜单不可用）
PTOE_DATABASE_URL=postgresql://ptoe:CHANGE_ME@host.docker.internal:5434/periodic_table_auth
PTOE_SESSION_SECRET=change-me-at-least-32-chars
PTOE_IDLE_RELEASE_DAYS=30
PTOE_MAX_DEVICES_DEFAULT=2

# 可选：GotIt 课本单词通（不配置则 padmin GotIt 菜单不可用）
GOTIT_DATABASE_URL=postgresql://gotit:CHANGE_ME@host.docker.internal:5435/gotit
